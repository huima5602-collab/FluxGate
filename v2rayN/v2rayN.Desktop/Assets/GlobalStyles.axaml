<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <!--  Add Controls for Previewer Here  -->
        </Border>
    </Design.PreviewWith>

    <Style Selector="DataGrid">
        <Setter Property="RowHeight" Value="24" />
        <Setter Property="Background" Value="{DynamicResource FluxPanelBg}" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
    </Style>

    <Style Selector="PathIcon">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
    </Style>

    <Style Selector="TextBlock.FluxTitle">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.FluxSubtle">
        <Setter Property="Foreground" Value="{DynamicResource FluxTextMuted}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="TextBlock.FluxSectionTitle">
        <Setter Property="Foreground" Value="{DynamicResource FluxCyan}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.FluxHeroTitle">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.FluxHeroTitle.FluxHomeTitle">
        <Setter Property="FontSize" Value="22" />
    </Style>

    <Style Selector="TextBlock.FluxHeroText">
        <Setter Property="Foreground" Value="{DynamicResource FluxTextMuted}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.FluxPageTitle">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.FluxFooter">
        <Setter Property="Foreground" Value="{DynamicResource FluxTextMuted}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="Border.FluxSideLogo">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{DynamicResource FluxAccentGradient}" />
    </Style>

    <Style Selector="Border.FluxBrandMark">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="38" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Background" Value="{DynamicResource FluxAccentGradient}" />
    </Style>

    <Style Selector="Button.FluxNavButton">
        <Setter Property="Width" Value="46" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource FluxTextMuted}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.FluxNavButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.FluxNavButton.Active">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxCyan}" />
    </Style>

    <Style Selector="TextBlock.FluxNavHint">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Background" Value="{DynamicResource FluxPanelBgAlt}" />
    </Style>

    <Style Selector="Border.FluxPanel">
        <Setter Property="Background" Value="{DynamicResource FluxPanelBg}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="Border.FluxPanel.FluxMainPanel">
        <Setter Property="Background" Value="#0B1220" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="34" />
    </Style>

    <Style Selector="Border.FluxPanel.FluxWorkspace">
        <Setter Property="Background" Value="#0B1220" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="Padding" Value="30,28" />
    </Style>

    <Style Selector="Border.FluxPanel.FluxHomeShell">
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Border.FluxPanel.FluxCommandPanel">
        <Setter Property="MinHeight" Value="170" />
        <Setter Property="Padding" Value="22,18" />
    </Style>

    <Style Selector="Border.FluxPanel.FluxControlCard">
        <Setter Property="MinHeight" Value="84" />
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <Style Selector="Border.FluxPanel.FluxControlCard.Compact">
        <Setter Property="MinHeight" Value="72" />
        <Setter Property="Padding" Value="14,12" />
    </Style>

    <Style Selector="Border.FluxPanel.FluxTrafficPanel">
        <Setter Property="MinHeight" Value="170" />
        <Setter Property="Padding" Value="18,16" />
    </Style>

    <Style Selector="Border.FluxPanel.FluxNodePanel">
        <Setter Property="MinHeight" Value="170" />
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxPurple}" />
    </Style>

    <Style Selector="Border.FluxPanel.FluxWebViewPanel">
        <Setter Property="MinHeight" Value="420" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxPurple}" />
    </Style>

    <Style Selector="Border.FluxOnBadge">
        <Setter Property="Width" Value="92" />
        <Setter Property="Height" Value="92" />
        <Setter Property="CornerRadius" Value="92" />
        <Setter Property="Background" Value="{DynamicResource FluxGreen}" />
        <Setter Property="Margin" Value="24,0,16,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.FluxOnBadge.Compact">
        <Setter Property="Width" Value="72" />
        <Setter Property="Height" Value="72" />
        <Setter Property="CornerRadius" Value="72" />
        <Setter Property="Margin" Value="20,0,10,0" />
    </Style>

    <Style Selector="Border.FluxOnBadge.Off">
        <Setter Property="Background" Value="{DynamicResource FluxPanelBgAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxDanger}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.FluxMetricCard">
        <Setter Property="MinHeight" Value="58" />
        <Setter Property="Padding" Value="13,10" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource FluxPanelBgAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
    </Style>

    <Style Selector="Border.FluxMetricCard.Compact">
        <Setter Property="MinHeight" Value="54" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style Selector="Border.FluxMetricCard.Cyan">
        <Setter Property="BorderBrush" Value="{DynamicResource FluxCyan}" />
    </Style>

    <Style Selector="Border.FluxMetricCard.Orange">
        <Setter Property="BorderBrush" Value="{DynamicResource FluxOrange}" />
    </Style>

    <Style Selector="Border.FluxMetricCard.Green">
        <Setter Property="BorderBrush" Value="{DynamicResource FluxGreen}" />
    </Style>

    <Style Selector="Border.FluxMetricCard.Purple">
        <Setter Property="BorderBrush" Value="{DynamicResource FluxPurple}" />
    </Style>

    <Style Selector="TextBlock.FluxTinyLabel">
        <Setter Property="Foreground" Value="{DynamicResource FluxCyan}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.FluxMetricText">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.FluxSignalBar">
        <Setter Property="Background" Value="{DynamicResource FluxCyan}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Opacity" Value="0.85" />
    </Style>

    <Style Selector="Border.FluxMiniAction">
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxPurple}" />
        <Setter Property="Background" Value="#22163E" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style Selector="Button.FluxMiniActionButton">
        <Setter Property="MinWidth" Value="84" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="CornerRadius" Value="15" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxPurple}" />
        <Setter Property="Background" Value="#22163E" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style Selector="Button.FluxMiniActionButton.Compact">
        <Setter Property="MinWidth" Value="54" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="10,0" />
    </Style>

    <Style Selector="Border.FluxPill">
        <Setter Property="Background" Value="#1A2A45" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="12,7" />
    </Style>

    <Style Selector="Border.FluxPill.Success">
        <Setter Property="BorderBrush" Value="{DynamicResource FluxGreen}" />
    </Style>

    <Style Selector="Border.FluxPill.Cyan">
        <Setter Property="BorderBrush" Value="{DynamicResource FluxCyan}" />
    </Style>

    <Style Selector="Button.FluxToolButton">
        <Setter Property="MinWidth" Value="86" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="Background" Value="{DynamicResource FluxPanelBgAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.FluxToolButton.Cyan">
        <Setter Property="Foreground" Value="{DynamicResource FluxCyan}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxCyan}" />
    </Style>

    <Style Selector="Button.FluxToolButton.Green">
        <Setter Property="Foreground" Value="{DynamicResource FluxGreen}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxGreen}" />
    </Style>

    <Style Selector="Button.FluxToolButton.Purple">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxPurple}" />
        <Setter Property="Background" Value="#22163E" />
    </Style>

    <Style Selector="Border.FluxStatusDot">
        <Setter Property="Width" Value="9" />
        <Setter Property="Height" Value="9" />
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Background" Value="{DynamicResource FluxGreen}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Menu.FluxMenu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
    </Style>

    <Style Selector="FlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource FluxPanelBg}" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource FluxPanelBg}" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource FluxPanelBg}" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6" />
    </Style>

    <Style Selector="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="MenuItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1E3352" />
    </Style>

    <Style Selector="MenuItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#253C61" />
    </Style>

    <Style Selector="ContextMenu MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style Selector="ContextMenu MenuItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#243653" />
    </Style>

    <Style Selector="ContextMenu MenuItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="#2B4265" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource FluxPanelBgAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource FluxBlue}" />
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource FluxCyan}" />
    </Style>

    <Style Selector="TextBox.FluxLogTextArea">
        <Setter Property="Background" Value="{DynamicResource FluxPanelBg}" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
        <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Microsoft YaHei UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource FluxPanelBgAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxBorder}" />
    </Style>

    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="Background" Value="#1E3352" />
    </Style>

    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource FluxCyan}" />
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource FluxPanelBg}" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
    </Style>

    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#1E3352" />
    </Style>

    <Style Selector="Menu.FluxTopMenu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
    </Style>

    <Style Selector="Menu.FluxTopMenu > MenuItem">
        <Setter Property="MinWidth" Value="104" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="Background" Value="#22163E" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxPurple}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Menu.FluxToolbarMenu">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
    </Style>

    <Style Selector="Menu.FluxToolbarMenu > MenuItem">
        <Setter Property="MinWidth" Value="86" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="Background" Value="#22163E" />
        <Setter Property="BorderBrush" Value="{DynamicResource FluxPurple}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TabControl.FluxWorkspaceTabs">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="TabControl.FluxWorkspaceTabs TabItem">
        <Setter Property="Foreground" Value="{DynamicResource FluxTextMuted}" />
        <Setter Property="Padding" Value="11,9" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style Selector="TabControl.FluxWorkspaceTabs TabItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource FluxText}" />
        <Setter Property="Background" Value="{DynamicResource FluxAccentGradient}" />
    </Style>
</Styles>
