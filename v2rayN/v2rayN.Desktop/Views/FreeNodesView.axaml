<UserControl
    x:Class="v2rayN.Desktop.Views.FreeNodesView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:web="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView">
    <Grid RowDefinitions="Auto,*,Auto">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="8">
                <TextBlock Classes="FluxPageTitle" Text="免费节点" />
                <TextBlock Classes="FluxHeroText" Text="内嵌打开免费节点中心。若页面受登录、证书或 WebView2 环境影响无法加载，可以使用右侧浏览器入口。" />
            </StackPanel>
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="btnLoadFreeNodes"
                    Classes="FluxToolButton Purple"
                    Content="内嵌加载" />
                <Button
                    x:Name="btnReloadFreeNodes"
                    Classes="FluxToolButton Cyan"
                    Content="刷新" />
                <Button
                    x:Name="btnCopyFreeNodesUrl"
                    Classes="FluxToolButton"
                    Content="复制链接" />
                <Button
                    x:Name="btnOpenFreeNodes"
                    Classes="FluxToolButton Green"
                    Content="浏览器打开" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Margin="0,18,0,0"
            Classes="FluxPanel FluxWebViewPanel">
            <Grid>
                <web:NativeWebView x:Name="webFreeNodes" />
                <Border
                    x:Name="webFreeNodesPlaceholder"
                    Background="{DynamicResource FluxPanelBg}"
                    Padding="26">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                        <TextBlock
                            Classes="FluxSectionTitle"
                            HorizontalAlignment="Center"
                            Text="免费节点内嵌页" />
                        <TextBlock
                            Classes="FluxHeroText"
                            MaxWidth="560"
                            Text="为了避免 WebView2 或网页脚本异常导致主程序闪退，进入此页不会自动加载网页。点击“内嵌加载”后在这里打开；若仍不稳定，请使用浏览器打开。" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TextBlock
            Grid.Row="2"
            Margin="0,10,0,0"
            Classes="FluxHeroText"
            Text="提示：内嵌页面仅用于浏览，不读取网页数据；加载失败时请用浏览器打开。" />
    </Grid>
</UserControl>
