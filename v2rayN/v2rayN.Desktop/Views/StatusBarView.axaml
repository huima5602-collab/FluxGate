<UserControl
    x:Class="v2rayN.Desktop.Views.StatusBarView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:ServiceLib.Resx;assembly=ServiceLib"
    xmlns:vms="clr-namespace:ServiceLib.ViewModels;assembly=ServiceLib"
    d:DesignHeight="650"
    d:DesignWidth="1180"
    x:DataType="vms:StatusBarViewModel"
    mc:Ignorable="d">
    <Grid RowDefinitions="2*,Auto,3*">
        <Border Classes="FluxPanel FluxCommandPanel">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,*">
                <StackPanel Spacing="6">
                    <TextBlock Classes="FluxSectionTitle" Text="Minimal Command" />
                    <TextBlock
                        x:Name="txtRunningServerDisplay"
                        Classes="FluxHeroTitle"
                        FontSize="24"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="txtRunningInfoDisplay"
                        Classes="FluxHeroText"
                        Foreground="{DynamicResource FluxCyan}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1" Classes="FluxOnBadge">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="17"
                        FontWeight="Bold"
                        Foreground="#03120C"
                        Text="ON" />
                </Border>

                <Grid
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,24,0,0"
                    ColumnDefinitions="1.05*,1.05*,1.05*,1.05*">
                    <Border Classes="FluxMetricCard Cyan">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="FluxTinyLabel" Text="系统代理" />
                            <TextBlock Classes="FluxMetricText" Text="{Binding SystemProxyStatusDisplay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        Classes="FluxMetricCard Orange">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="FluxTinyLabel" Text="TUN 模式" />
                            <TextBlock Classes="FluxMetricText" Text="{Binding TunStatusDisplay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Margin="12,0,0,0"
                        Classes="FluxMetricCard Green">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="FluxTinyLabel" Text="本机代理端口" />
                            <TextBlock
                                x:Name="txtInboundDisplay"
                                Classes="FluxMetricText"
                                Text="{Binding LocalProxyAddressDisplay}"
                                TextWrapping="Wrap" />
                            <Button
                                x:Name="btnCopyLocalProxy"
                                Classes="FluxMiniActionButton"
                                Content="复制地址" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="3"
                        Margin="12,0,0,0"
                        Classes="FluxMetricCard Purple">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="FluxTinyLabel" Text="Core" />
                            <TextBlock Classes="FluxMetricText" Text="核心托管" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="0,14,0,0"
            ColumnDefinitions="1.25*,1.25*,Auto">
            <Border Classes="FluxPanel FluxControlCard">
                <StackPanel Spacing="8">
                    <TextBlock Classes="FluxSectionTitle" Text="{x:Static resx:ResUI.menuSystemproxy}" />
                    <ComboBox
                        x:Name="cmbSystemProxy"
                        HorizontalAlignment="Stretch"
                        ToolTip.Tip="{x:Static resx:ResUI.menuSystemproxy}">
                        <ComboBoxItem Content="{x:Static resx:ResUI.menuSystemProxyClear}" />
                        <ComboBoxItem Content="{x:Static resx:ResUI.menuSystemProxySet}" />
                        <ComboBoxItem Content="{x:Static resx:ResUI.menuSystemProxyNothing}" />
                        <ComboBoxItem Content="{x:Static resx:ResUI.menuSystemProxyPac}" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Margin="12,0,0,0"
                Classes="FluxPanel FluxControlCard">
                <StackPanel Spacing="8">
                    <TextBlock Classes="FluxSectionTitle" Text="{x:Static resx:ResUI.menuRouting}" />
                    <ComboBox
                        x:Name="cmbRoutings2"
                        HorizontalAlignment="Stretch"
                        DisplayMemberBinding="{Binding Remarks}"
                        ItemsSource="{Binding RoutingItems}"
                        ToolTip.Tip="{x:Static resx:ResUI.menuRouting}" />
                </StackPanel>
            </Border>

            <Border
                x:Name="spEnableTun"
                Grid.Column="2"
                Margin="12,0,0,0"
                Classes="FluxPanel FluxControlCard">
                <StackPanel Spacing="8">
                    <TextBlock Classes="FluxSectionTitle" Text="{x:Static resx:ResUI.TbEnableTunAs}" />
                    <ToggleSwitch
                        x:Name="togEnableTun"
                        HorizontalAlignment="Center"
                        Theme="{DynamicResource SimpleToggleSwitch}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid
            Grid.Row="2"
            Margin="0,14,0,0"
            ColumnDefinitions="0.9*,2.2*">
            <Border Classes="FluxPanel FluxTrafficPanel">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Classes="FluxSectionTitle" Text="实时代理" />
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="8">
                        <TextBlock
                            x:Name="txtSpeedProxyDisplay"
                            Foreground="{DynamicResource FluxGreen}"
                            FontSize="24"
                            FontWeight="SemiBold" />
                        <TextBlock
                            x:Name="txtSpeedDirectDisplay"
                            Foreground="{DynamicResource FluxOrange}"
                            FontSize="18"
                            FontWeight="SemiBold" />
                    </StackPanel>
                    <Grid
                        Grid.Row="2"
                        Height="42"
                        ColumnDefinitions="*,*,*,*,*,*,*,*,*,*,*,*"
                        VerticalAlignment="Bottom">
                        <Border Grid.Column="0" Height="14" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="1" Height="24" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="2" Height="18" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="3" Height="31" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="4" Height="21" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="5" Height="38" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="6" Height="26" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="7" Height="34" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="8" Height="19" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="9" Height="36" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="10" Height="28" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                        <Border Grid.Column="11" Height="41" Margin="4,0,0,0" Classes="FluxSignalBar" VerticalAlignment="Bottom" />
                    </Grid>
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Margin="12,0,0,0"
                Classes="FluxPanel FluxNodePanel">
                <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="FluxSectionTitle" Text="当前线路" />
                        <TextBlock
                            Classes="FluxHeroTitle"
                            FontSize="20"
                            Text="{Binding RunningServerDisplay}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Classes="FluxHeroText"
                            Text="{Binding RunningInfoDisplay}" />
                    </StackPanel>
                    <Button
                        x:Name="btnTestServerAvailability"
                        Grid.Column="1"
                        Classes="FluxMiniActionButton"
                        Content="测速" />
                    <TextBlock
                        x:Name="txtInboundLanDisplay"
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="0,18,0,0"
                        Classes="FluxHeroText"
                        VerticalAlignment="Bottom"
                        TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
